<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MR FUNNY HUB</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:#0a0a0a;
color:white;
line-height:1.6;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:black;
border-bottom:2px solid red;
}

nav h1{
color:red;
letter-spacing:2px;
}

nav ul{
display:flex;
list-style:none;
}

nav ul li{
margin-left:20px;
}

nav ul li a{
color:white;
text-decoration:none;
font-weight:bold;
}

nav ul li a:hover{
color:red;
}

/* HERO */

.hero{
height:80vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
background:linear-gradient(to bottom, #000000, #1a0000);
padding:20px;
}

.hero h2{
font-size:48px;
margin-bottom:20px;
}

.hero p{
font-size:20px;
opacity:0.8;
}

.hero a{
display:inline-block;
margin-top:25px;
padding:12px 25px;
background:red;
color:white;
text-decoration:none;
border-radius:5px;
font-weight:bold;
}

/* VIDEO SECTION */

.videos{
padding:60px 20px;
text-align:center;
}

.videos h2{
margin-bottom:30px;
color:red;
}

iframe{
max-width:100%;
border:none;
border-radius:10px;
}

/* ABOUT */

.about{
padding:60px 20px;
background:#111;
text-align:center;
}

.about h2{
color:red;
margin-bottom:20px;
}

.about p{
max-width:700px;
margin:auto;
font-size:18px;
}

/* FOOTER */

footer{
background:black;
padding:20px;
text-align:center;
border-top:2px solid red;
}

footer a{
color:red;
text-decoration:none;
}

/* MOBILE */

@media(max-width:768px){

.hero h2{
font-size:32px;
}

nav{
flex-direction:column;
}

nav ul{
margin-top:10px;
}

}

</style>
</head>

<body>

<!-- NAVBAR -->

<nav>
<h1>MR FUNNY HUB</h1>

<ul>
<li><a href="#home">Home</a></li>
<li><a href="#videos">Videos</a></li>
<li><a href="#about">About</a></li>
</ul>
</nav>

<!-- HOME -->

<section class="hero" id="home">

<div>
<h2>Welcome to Funny Hub 😂</h2>
<p>The internet's home for hilarious videos and clips.</p>

<a href="https://youtube.com/@mrfunny2026-jr?si=MbKUzAheIQkkSnjS" target="_blank">
Visit Our YouTube Channel
</a>
</div>

</section>

<!-- VIDEOS -->

<section class="videos" id="videos">

<h2>Latest Funny Videos 🎬</h2>

<iframe width="800" height="450"
src="https://www.youtube.com/embed?listType=user_uploads&list=mrfunny2026-jr">
</iframe>

</section>

<!-- ABOUT -->

<section class="about" id="about">

<h2>About MR FUNNY HUB</h2>

<p>
We repost funny videos and clips for many people around the world.
Our mission is simple — spread laughter and put a smile on your face.
Every video we share is meant to brighten your day and bring people together through humor.
</p>

</section>

<!-- FOOTER -->

<footer>

<p>Follow us on YouTube</p>

<a href="https://youtube.com/@mrfunny2026-jr?si=MbKUzAheIQkkSnjS">
MR FUNNY HUB Channel
</a>

<p style="margin-top:10px;">
© 2026 MR FUNNY HUB
</p>

</footer>

</body>
</html>
